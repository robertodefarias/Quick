<div class="quicktrip-hero py-5">
  <div class="container py-4">
    <div class="row justify-content-center text-center">
      <div class="col-lg-10">
        <span class="badge rounded-pill text-bg-light border mb-4 px-3 py-2 fade-in-up delay-1">
          Roteiros prontos em minutos
        </span>

        <div class="quicktrip-hero-logo fade-in-up delay-2">
          <span class="brand-text">
            Qu<span class="lightning">i</span>ckTrip
          </span>

  <div class="mt-4">
    <% if user_signed_in? %>

      <%= link_to "Create Trip", new_trip_path, class: "btn btn-primary btn-lg me-2" %>
      <%= link_to "My Trips", trips_path, class: "btn btn-outline-dark btn-lg" %>

      <div class="row mt-5">

        <% @cities.each do |city| %>

          <div class="col-md-4 mb-4">

            <div class="card shadow-sm h-100">
              <img src="https://source.unsplash.com/600x400/?<%= city.city %>" class="card-img-top">

              <div class="card-body">

                <h5 class="card-title">
                  <%= city.city %>
                </h5>

                <p class="card-text">
                  <%= truncate(city.content, length: 100) %>
                </p>

                <%= button_to "Explore",
                    chats_path(chat: { trip_id: city.id }),
                    method: :post,
                    class: "btn btn-primary" %>

              </div>

            </div>

          </div>

        <% end %>

      </div>

    <% else %>

      <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-primary btn-lg me-2" %>
      <%= link_to "Login", new_user_session_path, class: "btn btn-outline-dark btn-lg" %>

    <% end %>
  </div>
</div>
