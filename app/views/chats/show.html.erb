<div class="container py-5">

  <div id="messages" class="mb-4">

    <% @chat.messages.each do |message| %>

      <% if message.role == "user" %>
        <div class="text-end mb-3">
          <div class="bg-light p-3 rounded d-inline-block">
            <%= simple_format(message.content) %>
          </div>
        </div>

      <% else %>
        <div class="text-start mb-3">
          <div class="p-3 bg-white border rounded d-inline-block">
            <%= simple_format(message.content) %>
          </div>
        </div>
      <% end %>

    <% end %>

  </div>

  <!-- Formulário para continuar a conversa -->
  <div id="new_message_container" class="mt-4">

  <%= simple_form_for [@chat, @message] do |f| %>

    <div class="input-group">

      <%= f.input :content,
          label: false,
          placeholder: "Ask something about your trip...",
          wrapper: false,
          input_html: { class: "form-control form-control-lg" } %>

      <button class="btn btn-primary btn-lg" type="submit">
        Send
      </button>

    </div>

  <% end %>

</div>

</div>
