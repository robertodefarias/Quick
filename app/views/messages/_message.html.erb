<% if message.role == "user" %>

  <div class="d-flex justify-content-end mb-3">
    <div class="bg-primary text-white p-3 shadow-sm rounded-4 d-inline-block" style="max-width: 80%;">
      <%= simple_format(message.content, class: "mb-0") %>
    </div>
  </div>

<% else %>

  <div class="d-flex justify-content-start mb-3">
    <div class="bg-white border-0 shadow-sm p-3 rounded-4 d-inline-block" style="max-width: 80%;">
      <%= simple_format(message.content, class: "mb-0") %>
    </div>
  </div>

<% end %>
